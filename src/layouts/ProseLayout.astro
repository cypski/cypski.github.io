---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  ogType?: 'website' | 'article';
}

const { title, description, pubDate, updatedDate, tags, ogType = 'article' } = Astro.props;

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout {title} {description} {ogType}>
  <article class="page-container prose-page">
    <header class="prose-header">
      <h1>{title}</h1>
      {description && <p class="prose-description">{description}</p>}

      <div class="prose-meta">
        {pubDate && (
          <time datetime={pubDate.toISOString()} class="prose-date">
            {formatDate(pubDate)}
          </time>
        )}
        {updatedDate && (
          <span class="prose-updated">
            Updated {formatDate(updatedDate)}
          </span>
        )}
      </div>

      {tags && tags.length > 0 && (
        <ul class="tag-list" aria-label="Tags">
          {tags.map((tag) => <li><span class="tag">{tag}</span></li>)}
        </ul>
      )}
    </header>

    <div class="prose-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .prose-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .prose-description {
    font-size: 1.125rem;
    color: var(--color-muted);
    margin-top: 0.5rem;
    margin-bottom: 1rem;
  }

  .prose-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .prose-date, .prose-updated {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  /* ── Prose content typography ──────────────────────────── */
  .prose-content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .prose-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .prose-content :global(p) {
    margin-bottom: 1.25rem;
    line-height: 1.75;
    max-width: 70ch;
  }

  .prose-content :global(ul),
  .prose-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose-content :global(li) {
    margin-bottom: 0.4rem;
    line-height: 1.75;
  }

  .prose-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    margin: 1.5rem 0;
    padding: 0.25rem 0 0.25rem 1.25rem;
    color: var(--color-muted);
    font-style: italic;
  }

  .prose-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .prose-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .prose-content :global(th),
  .prose-content :global(td) {
    text-align: left;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
  }

  .prose-content :global(th) {
    background: var(--color-surface);
    font-weight: 600;
  }
</style>
