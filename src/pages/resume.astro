---
import BaseLayout from '../layouts/BaseLayout.astro';

interface EducationItem {
  school: string;
  location: string;
  degree: string;
  period: string;
  detail: string;
}

interface Publication {
  title: string;
  role: string;
  period: string;
  location: string;
  bullets: string[];
}

const education: EducationItem[] = [
  {
    school: 'The Hertie School',
    location: 'Berlin, Germany',
    degree: 'Master of International Affairs',
    period: 'July 2025 – June 2026',
    detail: 'Concentration in international security.',
  },
  {
    school: 'Syracuse University',
    location: 'Syracuse, NY, USA',
    degree: 'Master of Public Administration',
    period: 'July 2024 – June 2025',
    detail: 'Focus on technology policy.',
  },
  {
    school: 'Purdue University',
    location: 'West Lafayette, IN, USA',
    degree: 'Bachelor of Arts in Political Science',
    period: 'August 2020 – May 2024',
    detail: 'Minor in French with a certificate in public policy.',
  },
];

const publications: Publication[] = [
  {
    title: '"Artificial Intelligence and Its Use in Combat"',
    role: 'Co-author',
    period: 'June 2025',
    location: 'Syracuse, NY, USA',
    bullets: [
      'Prepared for the benefit of the Dnistrianskyi Centre in Lwów, Ukraine.',
      'Explores the future ethical and legal implications of artificial intelligence in combat through practical examples from the Russo-Ukrainian war and translates technical concepts for diverse audiences.',
    ],
  },
  {
    title: '"Term Frequency and Sentiment in AI Standards"',
    role: 'Author',
    period: 'May 2025',
    location: 'Syracuse, NY, USA',
    bullets: [
      'Considers 30 externally available AI standards frameworks published by three distinct organisation types.',
      'Contrasts frameworks by examining term frequency and phrase sentiment scores, revealing nuanced similarities and differences in the processed frameworks.',
    ],
  },
  {
    title: '"Polarization of Electric Vehicles in Partisan News"',
    role: 'Co-author',
    period: 'May 2024',
    location: 'West Lafayette, IN, USA',
    bullets: [
      'Published in the 17th volume of the Pepperdine Policy Review.',
      'Findings demonstrate a differential treatment of electric vehicles across the aisle.',
    ],
  },
];

const skills: Record<string, string[]> = {
  Certificates: [
    'DataCamp: Data Scientist in Python',
    'Wharton School Online: Artificial Intelligence for Business',
    'Lund University: Artificial Intelligence and Law (MOOC)',
  ],
  Data: ['Python', 'SQL', 'Visual Studio Code', 'GitHub (Git)', 'QGIS', 'STATA', 'Zotero', 'Qualtrics', 'Tableau'],
  Media: ['Microsoft Office Suite', 'Adobe InDesign', 'Adobe Photoshop', 'Adobe Premiere', 'Canva', 'WordPress'],
  Languages: ['English (native)', 'French (C1)', 'German (B1)'],
};
---

<BaseLayout title="Resume" description="Education, publications, and skills.">
  <div class="page-container">
    <header class="resume-header">
      <div>
        <h1>Casimir Wypyski</h1>
        <p class="resume-tagline">International Affairs &middot; Technology Policy</p>
      </div>
    </header>

    <!-- Education -->
    <section class="resume-section">
      <h2 class="section-title">Education</h2>
      <div class="education-list">
        {education.map((item) => (
          <article class="education-item">
            <div class="education-main">
              <div>
                <strong>{item.school}</strong>
                <p class="education-degree">{item.degree}</p>
                <p class="education-detail">{item.detail}</p>
              </div>
              <div class="education-meta">
                <time class="job-period">{item.period}</time>
                <span class="job-period">{item.location}</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Publications -->
    <section class="resume-section">
      <h2 class="section-title">Publications</h2>
      <div class="job-list">
        {publications.map((pub) => (
          <article class="job">
            <div class="job-header">
              <div>
                <h3 class="job-title">{pub.title}</h3>
                <p class="job-company">{pub.role} &middot; {pub.location}</p>
              </div>
              <time class="job-period">{pub.period}</time>
            </div>
            <ul class="job-bullets">
              {pub.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <!-- Skills -->
    <section class="resume-section">
      <h2 class="section-title">Skills</h2>
      <dl class="skills-grid">
        {Object.entries(skills).map(([category, items]) => (
          <>
            <dt class="skills-category">{category}</dt>
            <dd class="skills-items">
              <ul class="tag-list">
                {items.map((skill) => <li><span class="tag">{skill}</span></li>)}
              </ul>
            </dd>
          </>
        ))}
      </dl>
    </section>
  </div>
</BaseLayout>

<style>
  /* Header */
  .resume-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .resume-header h1 {
    margin-bottom: 0.25rem;
  }

  .resume-tagline {
    color: var(--color-muted);
    margin: 0;
  }

  /* Sections */
  .resume-section {
    margin-bottom: 2.75rem;
  }

  .section-title {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  /* Jobs */
  .job-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .job-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .job-title {
    font-size: 1.05rem;
    margin: 0 0 0.2rem;
  }

  .job-company {
    font-size: 0.9rem;
    color: var(--color-muted);
    margin: 0;
  }

  .job-period {
    font-size: 0.825rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .job-bullets {
    margin: 0;
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .job-bullets li {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-muted);
  }

  /* Skills */
  .skills-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem 1.5rem;
    align-items: start;
    margin: 0;
  }

  .skills-category {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    padding-top: 0.2rem;
  }

  .skills-items {
    margin: 0;
  }

  /* Education */
  .education-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .education-main {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .education-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
    flex-shrink: 0;
  }

  .education-degree {
    font-size: 0.9rem;
    color: var(--color-muted);
    margin: 0.2rem 0 0;
  }

  .education-detail {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin: 0.2rem 0 0;
    font-style: italic;
  }

  @media (max-width: 500px) {
    .resume-contact {
      align-items: flex-start;
    }
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
