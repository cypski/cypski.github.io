---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<BaseLayout title="Blog" description="Thoughts on international affairs, technology policy, and AI governance.">
  <div class="page-container">
    <header class="page-header">
      <h1>Blog</h1>
      <p>Thoughts on international affairs, technology policy, and AI governance.</p>
    </header>

    {posts.length === 0 ? (
      <p class="empty-state">No posts yet — check back soon.</p>
    ) : (
      <ul class="post-list" role="list">
        {posts.map((post) => (
          <li class="post-item">
            <article>
              <a href={`/blog/${post.id}`} class="post-title-link">
                <h2 class="post-title">{post.data.title}</h2>
              </a>
              <div class="post-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
              </div>
              <p class="post-description">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <ul class="tag-list" aria-label="Tags">
                  {post.data.tags.map((tag) => <li><span class="tag">{tag}</span></li>)}
                </ul>
              )}
            </article>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>

<style>
  .empty-state {
    color: var(--color-muted);
    font-size: 1.05rem;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .post-item {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-title-link {
    text-decoration: none;
    color: inherit;
  }

  .post-title-link:hover .post-title {
    color: var(--color-accent);
  }

  .post-title {
    font-size: 1.3rem;
    margin-bottom: 0.35rem;
    transition: color 0.15s;
  }

  .post-meta {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-bottom: 0.6rem;
  }

  .post-description {
    color: var(--color-muted);
    line-height: 1.65;
    margin-bottom: 0.75rem;
    max-width: 65ch;
  }
</style>
